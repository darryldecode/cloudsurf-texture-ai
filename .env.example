NEON_AUTH_BASE_URL=https://your-neon-auth-url
NEON_AUTH_JWKS_URL=https://your-neon-auth-jwks-url
# Generate this yourself with: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=your-app-cookie-secret-at-least-32-characters

DATABASE_URL=postgresql://user:password@ep-your-neon-host.region.aws.neon.tech/dbname?sslmode=require

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=your-private-texture-assets-bucket
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Optional override. Defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Image AI provider options: google, openai
IMAGE_AI_PROVIDER=google

# Google image provider options include:
# - gemini-3.1-flash-image-preview (recommended trial)
# - gemini-3-pro-image-preview
# - gemini-2.5-flash-image
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_IMAGE_MODEL=gemini-3.1-flash-image-preview
# Optional for Gemini 3 image models: 0.5K, 1K, 2K, 4K
GOOGLE_IMAGE_SIZE=2K

# OpenAI image provider fallback options include: gpt-image-2
OPENAI_API_KEY=your-openai-api-key
OPENAI_IMAGE_MODEL=gpt-image-2

# Paddle billing for credit recharges. Pricing is based on OpenAI image usage cost.
# Provider values: sandbox, production
PADDLE_ENVIRONMENT=sandbox
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-endpoint-secret
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your-paddle-client-side-token
# Optional override for the page Paddle returns as checkout.url. Defaults to <request-origin>/checkout.
PADDLE_CHECKOUT_URL=http://localhost:3000/checkout
# Optional canonical app URL used when creating checkout links outside localhost.
APP_URL=http://localhost:3000

# One-time Paddle price IDs for OpenAI-based credit packs:
# starter: 25 credits for $39
# production: 100 credits for $129
# studio: 250 credits for $279
PADDLE_STARTER_PRICE_ID=pri_your_starter_price_id
PADDLE_PRODUCTION_PRICE_ID=pri_your_production_price_id
PADDLE_STUDIO_PRICE_ID=pri_your_studio_price_id
